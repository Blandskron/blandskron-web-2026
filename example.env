DJANGO_SECRET_KEY=replace-with-a-random-secret

DJANGO_DEBUG=False
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

EMAIL_HOST=mail.tudominio.com
EMAIL_PORT=465
EMAIL_USE_SSL=true
EMAIL_USE_TLS=false
EMAIL_HOST_USER=noreply@tudominio.com
EMAIL_HOST_PASSWORD=replace-with-smtp-password
DEFAULT_FROM_EMAIL=Your Name <noreply@example.com>
CONTACT_NOTIFY_EMAIL=owner@example.com
EMAIL_SUBJECT_PREFIX=[tudominio] 
EMAIL_TIMEOUT=20

# Configuración del Superusuario Automático
DJANGO_SUPERUSER_USERNAME=replace-with-admin-username
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=replace-with-a-strong-password
