DJANGO_SECRET_KEY=tukey

DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=tuhost

EMAIL_HOST=mail.tudominio.com
EMAIL_PORT=465
EMAIL_USE_SSL=true
EMAIL_USE_TLS=false
EMAIL_HOST_USER=noreply@tudominio.com
EMAIL_HOST_PASSWORD=password1234
DEFAULT_FROM_EMAIL=tudominio <noreply@tudominio.com>
CONTACT_NOTIFY_EMAIL=noreply@tudominio.com
EMAIL_SUBJECT_PREFIX=[tudominio] 
EMAIL_TIMEOUT=20

# Configuración del Superusuario Automático
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@gmail.com
DJANGO_SUPERUSER_PASSWORD=admin1234
